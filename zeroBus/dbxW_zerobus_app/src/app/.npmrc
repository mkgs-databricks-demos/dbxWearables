# Reduce npm memory pressure during Databricks App deployments.
#
# The App container has limited memory. npm's default behavior causes OOM
# during cold installs with native modules (zerobus-ingest-sdk NAPI-RS,
# sharp). Symptoms:
#   - "Exit handler never called!" after ~8-11 min of npm install
#   - ENOTEMPTY on subsequent deploys (stale node_modules from OOM crash)
#
# These settings are read by npm before any commands, even when the
# platform runs `npm install --ignore-scripts`.

# Limit parallel HTTP connections (default: 15 → 4)
maxsockets=4

# Skip optionalDependencies — heavy packages (playwright, sharp) that
# aren't needed for the build or runtime. Saves ~200MB+ of downloads
# and native compilation memory.
omit=optional

# Retry transient network failures
fetch-retries=3
fetch-retry-mintimeout=10000
fetch-retry-maxtimeout=60000

# Skip non-essential post-install work
fund=false
audit=false
progress=false
